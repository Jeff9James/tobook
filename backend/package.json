{
  "name": "tobook-backend",
  "version": "1.0.0",
  "description": "Express backend for Markdown to KDP book conversion",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && cp -r src/templates dist/ && cp -r src/filters dist/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "tar": "^6.2.0",
    "node-fetch": "^2.7.0",
    "child-process-promise": "^2.2.1",
    "fs-extra": "^11.2.0",
    "archiver": "^6.0.1",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/tar": "^6.1.11",
    "@types/node-fetch": "^2.6.9",
    "@types/child-process-promise": "^2.2.6",
    "@types/fs-extra": "^11.0.4",
    "@types/archiver": "^6.0.2",
    "@types/node": "^20.10.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
